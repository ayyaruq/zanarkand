# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, build with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Go dependency crap
/vendor/
/Godeps/

# Editor/IDE - we allow only vscode
.idea/

# Debugging objects
*.pcap

# Example binaries
/examples/**/*
!/examples/**/*.go
